{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "defaultLocale": {
      "type": "string",
      "minLength": 1
    },
    "locales": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "localeDir": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "default": "openai",
      "type": "string",
      "minLength": 1
    },
    "apiKey": {
      "type": "string",
      "minLength": 1
    },
    "baseURL": {
      "type": "string",
      "format": "uri"
    },
    "glossary": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "maxRetries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "processor": {
      "type": "string",
      "enum": [
        "passthrough",
        "icu"
      ]
    },
    "modelParams": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "batchSize": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "quality": {
      "type": "object",
      "properties": {
        "threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "maxRetries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      },
      "additionalProperties": false
    },
    "format": {
      "type": "string"
    },
    "skipPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "concurrency": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    }
  },
  "required": [
    "defaultLocale",
    "locales",
    "localeDir",
    "provider",
    "apiKey"
  ],
  "additionalProperties": false,
  "$id": "https://www.schemastore.org/intl-ai.json",
  "title": "intl-ai config",
  "description": "Configuration for the intl-ai translation build step"
}
