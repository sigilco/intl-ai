{
  "name": "@intl-ai/core",
  "version": "0.0.1",
  "description": "AI-powered i18n translation core library",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espetro/intl-ai.git"
  },
  "homepage": "https://intl-ai.illo.fyi/",
  "bugs": "https://github.com/espetro/intl-ai/issues",
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "ai",
    "intl"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "http://localhost:4873"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/provider": "0.0.1",
    "@formatjs/icu-messageformat-parser": "3.5.7",
    "ai": "6.0.177",
    "jiti": "1.21.7",
    "yaml": "2.9.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "20.19.40",
    "tsdown": "0.21.10",
    "typescript": "5.5.4"
  }
}