{
  "name": "@intl-ai/cli",
  "version": "0.0.1",
  "license": "MIT",
  "description": "CLI for AI-powered i18n translation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espetro/intl-ai.git"
  },
  "homepage": "https://github.com/espetro/intl-ai#readme",
  "bugs": "https://github.com/espetro/intl-ai/issues",
  "keywords": [
    "cli",
    "i18n",
    "internationalization",
    "translation",
    "ai",
    "intl"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "intl-ai": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "http://localhost:4873"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@intl-ai/core": "workspace:*",
    "commander": "^14.0.3",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.0.0",
    "tsdown": "^0.21.4",
    "typescript": "5.5.4"
  }
}