{
  "name": "@intl-ai/cli",
  "version": "0.3.0",
  "description": "CLI for AI-powered i18n translation",
  "keywords": [
    "ai",
    "cli",
    "i18n",
    "internationalization",
    "intl",
    "translation"
  ],
  "homepage": "https://intl-ai.pages.dev",
  "bugs": "https://github.com/sigilco/intl-ai/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigilco/intl-ai.git"
  },
  "bin": {
    "intl-ai": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@intl-ai/api": "workspace:*",
    "citty": "0.1.6",
    "consola": "3.4.2",
    "jiti": "2.7.0",
    "pathe": "1.1.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "tsdown": "0.22.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
