{
  "name": "@intl-ai/next",
  "version": "0.3.0",
  "description": "Turbopack bridge for @intl-ai/unplugin in Next.js 15+ apps",
  "keywords": [
    "ai",
    "i18n",
    "internationalization",
    "intl",
    "next",
    "nextjs",
    "translation"
  ],
  "homepage": "https://intl-ai.pages.dev",
  "bugs": "https://github.com/sigilco/intl-ai/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigilco/intl-ai.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@intl-ai/api": "workspace:*",
    "@intl-ai/unplugin": "workspace:*",
    "jiti": "2.7.0",
    "pathe": "2.0.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "next": "15.5.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  }
}
