{
  "name": "intl-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "publish:local": "turbo run build --filter='./packages/*' && pnpm -r --filter='./packages/*' publish --no-git-checks --registry http://localhost:4873",
    "dev:registry": "turbo watch build --filter='./packages/*'",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "release": "turbo run build && changeset publish",
    "validate": "bun scripts/validate.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tasuku": "^2.3.0",
    "turbo": "^2.8.17",
    "vitepress": "^1.5.0",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  }
}