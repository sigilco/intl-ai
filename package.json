{
  "name": "intl-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter='./packages/*'",
    "build:cli": "bun build packages/cli/src/index.ts --compile --outfile dist/binaries/intl-ai",
    "dev": "turbo run dev --filter='./packages/*'",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "turbo run test --filter='./packages/*'",
    "typecheck": "turbo run typecheck --filter='./packages/*'",
    "docs:dev": "vitepress dev docs",
    "sync:schema": "cp packages/api/src/schema/intl-ai.schema.json docs/public/schema/v1.json",
    "demo:render": "vhs docs/public/intl-ai-demo.tape",
    "docs:i18n:sync": "bun docs/i18n/i18n.mts sync",
    "docs:i18n:fill": "pnpm docs:i18n:sync && bun docs/i18n/i18n.mts fill",
    "docs:i18n:build": "bun docs/i18n/i18n.mts build",
    "predocs:build": "pnpm sync:schema",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "publish:local": "turbo run build --filter='./packages/*' && pnpm -r --filter='./packages/*' publish --no-git-checks --registry http://localhost:4873",
    "dev:registry": "turbo watch build --filter='./packages/*'",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "release": "turbo run build && changeset publish",
    "validate": "bun scripts/validate.ts"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@vitest/coverage-v8": "catalog:",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "tasuku": "2.3.0",
    "turbo": "2.10.1",
    "typescript": "catalog:",
    "vitepress": "1.6.4",
    "vitepress-plugin-group-icons": "1.7.5",
    "vitepress-plugin-llms": "^1.13.0",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.18.0 || >=24"
  },
  "packageManager": "pnpm@11.5.0"
}
