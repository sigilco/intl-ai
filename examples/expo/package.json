{
  "name": "@examples/expo",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:plugin": "tsdown --config plugin/tsdown.config.ts",
    "typecheck:plugin": "tsc --project plugin/tsconfig.json --noEmit",
    "test:plugin": "vitest run --config plugin/vitest.config.ts"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "react": "18.3.1",
    "react-native": "0.76.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/config-plugins": "9.0.17",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "pathe": "2.0.3",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
